{{- define "neighborenableipfamily"}}
{{- $peer := .Addr }}
{{- /* Unnummber BGP */}}
{{- if ne .Iface "" }}
  {{- $peer = .Iface }}
{{- end }}
{{/* no bgp default ipv4-unicast prevents peering if no address families are defined. We declare an ipv4 one for the peer to make the pairing happen */}}
{{- if activateNeighborFor "ipv4" .IPFamily .AddressFamilies }}
  address-family ipv4 unicast
    neighbor {{$peer}} activate
    neighbor {{$peer}} route-map {{.ID}}-in in
    neighbor {{$peer}} route-map {{.ID}}-out out
{{- if eq .AllowAsIn "any" }}
    neighbor {{$peer}} allowas-in
{{- else if eq .AllowAsIn "origin" }}
    neighbor {{$peer}} allowas-in origin
{{- end }}
  exit-address-family
{{- end -}}
{{if activateNeighborFor "ipv6" .IPFamily .AddressFamilies }}
  address-family ipv6 unicast
    neighbor {{$peer}} activate
    neighbor {{$peer}} route-map {{.ID}}-in in
    neighbor {{$peer}} route-map {{.ID}}-out out
{{- if eq .AllowAsIn "any" }}
    neighbor {{$peer}} allowas-in
{{- else if eq .AllowAsIn "origin" }}
    neighbor {{$peer}} allowas-in origin
{{- end }}
  exit-address-family
{{- end -}}
{{- end -}}
